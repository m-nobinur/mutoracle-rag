# Required only for commands that call OpenRouter-backed models.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional OpenRouter attribution headers.
OPENROUTER_APP_TITLE=MutOracle-RAG
OPENROUTER_APP_URL=

# Fallback local safety defaults when no YAML config is loaded.
# Prefer experiments/configs/dev.yaml as the project source of truth.
MUTORACLE_MAX_COST_USD=5.00
MUTORACLE_MAX_QUERIES=20
MUTORACLE_CACHE_PATH=.mutoracle/cache.sqlite3
MUTORACLE_PROMPT_COST_PER_1M_TOKENS=0.00
MUTORACLE_COMPLETION_COST_PER_1M_TOKENS=0.00
